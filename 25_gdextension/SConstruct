#!/usr/bin/env python
# SCons 构建脚本。godot-cpp 必须先克隆到 godot-cpp/ 子目录并 build 过。
#
# 用法:
#   scons platform=windows target=template_debug -j8
#   scons platform=windows target=template_release -j8
#   scons platform=linux   target=template_debug -j8
#   scons platform=macos   target=template_debug -j8
#   scons platform=android target=template_debug arch=arm64 -j8

import os
import sys

env = SConscript("godot-cpp/SConstruct")

# 头文件搜索路径
env.Append(CPPPATH=["src/"])

# 源文件
sources = Glob("src/*.cpp")

# 输出文件名
if env["platform"] == "macos":
    library = env.SharedLibrary(
        "bin/libgodotstuff.{}.{}.framework/libgodotstuff.{}.{}".format(
            env["platform"], env["target"],
            env["platform"], env["target"],
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "bin/libgodotstuff{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

Default(library)
