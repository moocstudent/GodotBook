; ====== CSG 关卡 ============================================
; CSGCombiner3D 的 use_collision = true 时,根据合并出的 mesh 自动生成碰撞体。
; 子节点 operation:0=union(加),1=intersection(交),2=subtraction(减)

[node name="Level" type="CSGCombiner3D" parent="."]
